# --- DATABASE (Supabase) ---
# For Backend (VPS)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For Frontend (Vercel)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- PAYMENTS (Stripe) ---
# TEST MODE ONLY
STRIPE_SECRET_KEY=sk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- EMAILS (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@send.thelumaflow.com
ADMIN_EMAIL=your-admin@email.com

# --- APPLICATION URLS ---
# Backend URL (Frontend needs this)
VITE_API_URL=https://api.thelumaflow.com/api

# Frontend URL (Backend needs this for CORS and redirects)
FRONTEND_URL=https://thelumaflow.com

# Other Site URLs
NEXT_PUBLIC_SITE_URL=https://thelumaflow.com

# --- ZOOM INTEGRATION (Server-to-Server OAuth) ---
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_USER_EMAIL=your-zoom-account-email

# --- SERVER CONFIG ---
PORT=3001
NODE_ENV=production
